# Optional: Set a custom API URL (eg, for local endpoints like Ollama, LM Studio, or vLLM)
# API_URL=http://localhost:11434/v1

# Optional: Set the API Key (a dummy key is used by default if none provided)
# API_KEY=your-api-key

# Optional: Set the model name to use (defaults to gpt-5-mini)
# MODEL_NAME=gpt-5-mini
